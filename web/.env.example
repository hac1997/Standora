# Banco de dados PostgreSQL (Neon, Supabase, Render, etc.)
# Formato: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/standora?sslmode=require"

# Segredo de autenticação — gere um novo com: openssl rand -base64 32
AUTH_SECRET="standora-mvp-secret-change-in-production"

# URL base da aplicação (em produção: https://seu-dominio.vercel.app)
AUTH_URL="http://localhost:3000"

# Cloudinary — upload de imagens (croquis, fotos de estandes)
# Crie sua conta gratuita em https://cloudinary.com
CLOUDINARY_CLOUD_NAME="seu_cloud_name"
CLOUDINARY_API_KEY="sua_api_key"
CLOUDINARY_API_SECRET="seu_api_secret"
